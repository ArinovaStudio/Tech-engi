generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                   String                       @id @default(uuid())
  name                 String?
  email                String                       @unique
  emailVerified        DateTime?
  password             String?
  role                 Role
  image                String?
  lastActiveAt         DateTime                     @default(now())
  isSuspended          Boolean                      @default(false)
  bio                  String?
  phone                String?
  accounts             Account[]
  clientProfile        ClientProfile?
  conversationsAsUser1 Conversation[]               @relation("User1Conversations")
  conversationsAsUser2 Conversation[]               @relation("User2Conversations")
  sentDirectMessages   DirectMessage[]
  engineerProfile      EngineerProfile?
  featureRequests      FeatureRequest[]
  kanbanComments       KanbanComment[]
  kanbanReports        KanbanReport[]
  assignedKanbanTasks  KanbanTask[]                 @relation("TaskAssignee")
  createdKanbanTasks   KanbanTask[]                 @relation("TaskCreator")
  milestones           Milestone[]
  payoutDetail         PayoutDetail?
  cancellationRequests ProjectCancellationRequest[]
  projectMessages      ProjectMessage[]
  addedResources       ProjectResource[]
  projectTasks         ProjectTask[]
  raisedTickets        Ticket[]
  transactions         Transaction[]
}

model ClientProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  totalProjects Int       @default(0)
  totalBudget   Float     @default(0)
  expertise     String[]
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      Project[]
}

model EngineerProfile {
  id                      String                 @id @default(uuid())
  userId                  String                 @unique
  status                  ApprovalStatus         @default(PENDING)
  rejectionReason         String?
  qualification           Qualification
  idType                  IdType
  idNumber                String
  skills                  String[]
  embedding               Unsupported("vector")?
  completedProjects       Int                    @default(0)
  createdAt               DateTime               @default(now())
  idFile                  String
  certifications          Json                   @default("[]")
  yearsOfExperience       ExperienceLevel?
  yearsOfExperienceNumber Int?                   @default(0)
  achievements            String[]
  github                  String?
  linkedin                String?
  portfolio               String?
  qualificationType       String?
  university              String?
  user                    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedWork            Project[]
  invitations             ProjectInvitation[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model PayoutDetail {
  id              String  @id @default(uuid())
  userId          String  @unique
  upiId           String?
  accountNumber   String?
  ifscCode        String?
  bankName        String?
  accountHolder   String?
  preferredMethod String  @default("UPI")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id                   String                       @id @default(uuid())
  clientId             String
  engineerId           String?
  title                String
  description          String
  budget               Float
  instruments          String[]
  advancePaid          Boolean                      @default(false)
  status               ProjectStatus                @default(DRAFT)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  endDate              DateTime?
  startDate            DateTime?
  finalProjectLink     String?
  isEngineerFinished   Boolean                      @default(false)
  isFinalPaymentMade   Boolean                      @default(false)
  progress             Int                          @default(0)
  priority             ProjectPriority              @default(LOW)
  repository           String?
  currentPhase         String[]
  technology           Json?
  extensionRequests    DeadlineExtensionRequest[]
  designSystem         DesignSystem?
  featureRequests      FeatureRequest[]
  kanbanTasks          KanbanTask[]
  latestUpdates        LatestUpdate[]
  milestones           Milestone[]
  client               ClientProfile                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  engineer             EngineerProfile?             @relation(fields: [engineerId], references: [id])
  cancellationRequests ProjectCancellationRequest[]
  invitations          ProjectInvitation[]
  projectMessages      ProjectMessage[]
  resources            ProjectResource[]
  projectTasks         ProjectTask[]
  tickets              Ticket[]
  transactions         Transaction[]
}

model DesignSystem {
  id               String   @id @default(uuid())
  projectId        String   @unique
  brandName        String
  colors           String[]
  fonts            Json
  designType       String[]
  layoutStyle      Json
  contentTone      String[]
  visualGuidelines Json
  theme            String[]
  brandFeel        String
  keyPages         String[]
  uniqueness       Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LatestUpdate {
  id        String   @id @default(cuid())
  title     String
  date      String
  projectId String
  createdBy String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model FeatureRequest {
  id          String   @id @default(cuid())
  clientId    String
  projectId   String
  title       String
  description String
  createdAt   DateTime @default(now())
  status      String   @default("pending")
  client      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectResource {
  id        String       @id @default(uuid())
  projectId String
  addedById String
  title     String
  type      ResourceType
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  isLocked  Boolean      @default(false)
  addedBy   User         @relation(fields: [addedById], references: [id], onDelete: Cascade)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectInvitation {
  id         String           @id @default(uuid())
  projectId  String
  engineerId String?
  status     InvitationStatus @default(PENDING_ADMIN)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  engineer   EngineerProfile? @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, engineerId])
}

model ProjectCancellationRequest {
  id            String        @id @default(uuid())
  projectId     String
  requestedById String
  initiator     Initiator
  reason        String
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy   User          @relation(fields: [requestedById], references: [id], onDelete: Cascade)
}

model DeadlineExtensionRequest {
  id               String        @id @default(uuid())
  projectId        String
  requestedEndDate DateTime
  reason           String
  status           RequestStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String          @id @default(uuid())
  user1Id       String
  user2Id       String
  lastMessage   String?
  lastMessageAt DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user1         User            @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2         User            @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)
  messages      DirectMessage[]

  @@unique([user1Id, user2Id])
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isEdited       Boolean      @default(false)
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isDeleted      Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model ProjectMessage {
  id        String   @id @default(uuid())
  projectId String
  senderId  String
  content   String
  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String       @id @default(uuid())
  projectId   String
  raisedById  String
  issueType   TicketType
  description String
  images      String[]
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  target      TicketTarget @default(PLATFORM)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedBy    User         @relation(fields: [raisedById], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String            @id @default(uuid())
  projectId         String
  userId            String
  amount            Float
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  razorpayOrderId   String?           @unique
  razorpayPaymentId String?           @unique
  razorpaySignature String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  proof             String?
  completedAt       DateTime?
  razorpayPayoutId  String?           @unique
  razorpayRefundId  String?           @unique
  payuHash          String?
  payuPaymentId     String?           @unique
  payuTransactionId String?           @unique
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      Otptype
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type])
}

model ProjectTask {
  id          String   @id @default(uuid())
  projectId   String
  createdById String
  title       String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdById])
  @@index([date])
}

model Milestone {
  id          String        @id @default(uuid())
  projectId   String
  addedById   String
  title       String
  type        MilestoneType
  content     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completed   Boolean       @default(false)
  description String?
  addedBy     User          @relation(fields: [addedById], references: [id], onDelete: Cascade)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model KanbanTask {
  id          String             @id @default(uuid())
  projectId   String
  creatorId   String
  assigneeId  String?
  title       String
  description String?
  dueDate     DateTime?
  priority    KanbanTaskPriority @default(MEDIUM)
  status      KanbanTaskStatus   @default(NOT_STARTED)
  tags        String[]
  attachments String[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  comments    KanbanComment[]
  reports     KanbanReport[]
  assignee    User?              @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User               @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model KanbanComment {
  id        String     @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  task      KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model KanbanReport {
  id         String     @id @default(uuid())
  taskId     String
  reporterId String
  message    String
  createdAt  DateTime   @default(now())
  reporter   User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  task       KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Lead {
  id String @id @default(cuid())

  userType String
  domain   String
  blocker  String @db.Text
  stage    String
  budget   String
  timeline String

  name  String
  email String
  phone String?

  goal String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  CLIENT
  ENGINEER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Qualification {
  UG
  EMPLOYED
  UNEMPLOYED
}

enum IdType {
  STUDENT_ID
  AADHAAR
  PAN
  PAY_SLIP
}

enum ExperienceLevel {
  FRESHER
  ONE_TO_TWO_YEARS
  THREE_TO_FIVE_YEARS
  FIVE_TO_EIGHT_YEARS
  EIGHT_PLUS_YEARS
}

enum ProjectStatus {
  DRAFT
  SEARCHING
  IN_PROGRESS
  IN_REVIEW
  AWAITING_FINAL_PAYMENT
  COMPLETED
  CANCELED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

enum ResourceType {
  FILE
  CREDENTIALS
  IMAGE
  LINK
  TEXT
}

enum InvitationStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  DROPPED
  PENDING_ADMIN
  ADMIN_REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Initiator {
  CLIENT
  ENGINEER
}

enum TicketType {
  PAYMENT
  COMMUNICATION
  TECHNICAL
  DELIVERY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketTarget {
  PLATFORM
  CLIENT
  ENGINEER
}

enum TransactionType {
  ADVANCE_PAYMENT
  FINAL_PAYMENT
  REFUND_CLIENT
  PAYOUT_ENGINEER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Otptype {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum MilestoneType {
  IMAGE
  ZIP
  DOCUMENT
  LINK
}

enum KanbanTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum KanbanTaskStatus {
  ON_HOLD
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}
