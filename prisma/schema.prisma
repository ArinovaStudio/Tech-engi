generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Role {
  ADMIN
  CLIENT
  ENGINEER
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          Role
  image         String?
  lastActiveAt  DateTime  @default(now())

  accounts             Account[]
  clientProfile        ClientProfile?
  engineerProfile      EngineerProfile?
  payoutDetail         PayoutDetail?
  raisedTickets        Ticket[]
  addedResources       ProjectResource[]
  sentMessages         ChatMessage[]
  transactions         Transaction[]
  cancellationRequests ProjectCancellationRequest[]
  projectTasks         ProjectTask[]
  milestones           Milestone[]
  createdKanbanTasks   KanbanTask[] @relation("TaskCreator")
  assignedKanbanTasks  KanbanTask[] @relation("TaskAssignee")
  kanbanComments       KanbanComment[]
  kanbanReports        KanbanReport[]
}

model ClientProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  totalProjects Int      @default(0)
  totalBudget   Float    @default(0)
  expertise     String[]

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Qualification {
  UG
  EMPLOYED
  UNEMPLOYED
}

enum IdType {
  STUDENT_ID
  AADHAAR
  PAN
  PAY_SLIP
}

model EngineerProfile {
  id     String @id @default(uuid())
  userId String @unique

  status          ApprovalStatus @default(PENDING)
  rejectionReason String?        @db.Text
  qualification   Qualification
  idType          IdType
  idNumber        String
  idFile          String

  certifications    String[]
  skills            String[]
  embedding         Unsupported("vector(768)")?
  completedProjects Int                         @default(0)
  createdAt         DateTime                    @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedWork Project[]
  invitations  ProjectInvitation[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model PayoutDetail {
  id            String  @id @default(uuid())
  userId        String  @unique
  upiId         String?
  accountNumber String?
  ifscCode      String?
  bankName      String?
  accountHolder String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  DRAFT
  AWAITING_ADVANCE
  SEARCHING
  IN_PROGRESS
  IN_REVIEW
  AWAITING_FINAL_PAYMENT
  COMPLETED
  CANCELED
}

model Project {
  id         String  @id @default(uuid())
  clientId   String
  engineerId String?

  title       String
  description String   @db.Text
  budget      Float
  instruments String[]

  progress           Int     @default(0)
  finalProjectLink   String? @db.Text
  isEngineerFinished Boolean @default(false)

  advancePaid        Boolean @default(false)
  isFinalPaymentMade Boolean @default(false)

  status    ProjectStatus @default(DRAFT)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client   ClientProfile    @relation(fields: [clientId], references: [id])
  engineer EngineerProfile? @relation(fields: [engineerId], references: [id])

  invitations          ProjectInvitation[]
  tickets              Ticket[]
  resources            ProjectResource[]
  extensionRequests    DeadlineExtensionRequest[]
  cancellationRequests ProjectCancellationRequest[]
  messages             ChatMessage[]
  transactions         Transaction[]
  projectTasks         ProjectTask[]
  milestones           Milestone[]
  kanbanTasks          KanbanTask[]
}

enum ResourceType {
  FILE
  CREDENTIALS
  IMAGE
  LINK
  TEXT
}

model ProjectResource {
  id        String @id @default(uuid())
  projectId String
  addedById String

  title    String
  type     ResourceType
  content  String       @db.Text
  isLocked Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedBy User    @relation(fields: [addedById], references: [id], onDelete: Cascade)
}

enum InvitationStatus {
  PENDING_ADMIN
  SENT
  ACCEPTED
  REJECTED
  ADMIN_REJECTED
  EXPIRED
  DROPPED
}

model ProjectInvitation {
  id         String           @id @default(uuid())
  projectId  String
  engineerId String
  status     InvitationStatus @default(PENDING_ADMIN)
  createdAt  DateTime         @default(now())

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  engineer EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([projectId, engineerId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Initiator {
  CLIENT
  ENGINEER
}

model ProjectCancellationRequest {
  id            String        @id @default(uuid())
  projectId     String
  requestedById String
  initiator     Initiator
  reason        String        @db.Text
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User    @relation(fields: [requestedById], references: [id], onDelete: Cascade)
}

model DeadlineExtensionRequest {
  id               String        @id @default(uuid())
  projectId        String
  requestedEndDate DateTime
  reason           String        @db.Text
  status           RequestStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String  @id @default(uuid())
  projectId String
  senderId  String
  content   String  @db.Text
  isEdited  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum TicketType {
  PAYMENT
  COMMUNICATION
  TECHNICAL
  DELIVERY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketTarget {
  PLATFORM
  CLIENT
}

model Ticket {
  id         String @id @default(uuid())
  projectId  String
  raisedById String

  issueType   TicketType
  target      TicketTarget @default(PLATFORM)
  description String       @db.Text
  images      String[]
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedBy User    @relation(fields: [raisedById], references: [id], onDelete: Cascade)
}

enum TransactionType {
  ADVANCE_PAYMENT
  FINAL_PAYMENT
  REFUND_CLIENT
  PAYOUT_ENGINEER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Transaction {
  id        String            @id @default(uuid())
  projectId String
  userId    String
  amount    Float
  type      TransactionType
  status    TransactionStatus @default(PENDING)

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?
  proof String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Otptype {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      Otptype
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type])
}

model ProjectTask {
  id          String @id @default(uuid())
  projectId   String
  createdById String

  title       String
  description String?  @db.Text
  date        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdById])
  @@index([date])
}

enum MilestoneType {
  IMAGE
  ZIP
  DOCUMENT
  LINK
}

model Milestone {
  id          String        @id @default(uuid())
  projectId   String
  addedById   String
  title       String
  type        MilestoneType
  content     String        @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completed   Boolean @default(false)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedBy     User          @relation(fields: [addedById], references: [id], onDelete: Cascade)
}

enum KanbanTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum KanbanTaskStatus {
  ON_HOLD
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model KanbanTask {
  id          String             @id @default(uuid())
  projectId   String
  creatorId   String
  assigneeId  String?
  title       String
  description String?            @db.Text
  dueDate     DateTime?
  priority    KanbanTaskPriority @default(MEDIUM)
  status      KanbanTaskStatus   @default(NOT_STARTED)
  tags        String[]
  attachments String[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  comments KanbanComment[]
  reports KanbanReport[]

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User               @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee    User?              @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model KanbanComment {
  id        String     @id @default(uuid())
  taskId    String
  authorId  String
  content   String     @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  task      KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model KanbanReport {
  id         String     @id @default(uuid())
  taskId     String
  reporterId String
  message    String     @db.Text
  createdAt  DateTime   @default(now())

  task       KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reporter   User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}