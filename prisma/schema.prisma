generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
  ENGINEER
}

model User {
  id String @id @default(uuid())
  name String?
  email String @unique
  emailVerified DateTime?
  password String?
  role Role  
  image String?

  accounts Account[]
  clientProfile ClientProfile?
  engineerProfile EngineerProfile?
}

model ClientProfile {
  id String @id @default(uuid())
  userId String @unique
  totalProjects Int @default(0)
  totalBudget Float @default(0)
  expertise String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Qualification {
  UG
  EMPLOYED
  UNEMPLOYED
}

enum IdType {
  STUDENT_ID
  AADHAAR
  PAN
  PAY_SLIP
}

model EngineerProfile {
  id String @id @default(uuid())
  userId String @unique

  status ApprovalStatus @default(PENDING)
  rejectionReason String? @db.Text
  qualification Qualification
  idType IdType
  idNumber String
  idImage String
  
  certifications String[]
  skills String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedWork Project[]
}

model Account {
  id String @id @default(uuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? @db.Text
  access_token String? @db.Text
  expires_at Int?
  token_type String?
  scope String?
  id_token String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}


enum ProjectStatus {
  DRAFT
  AWAITING_ADVANCE
  SEARCHING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum Otptype {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model Otp {
  id String @id @default(uuid())
  email String
  code String
  type Otptype
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type])
}

model Project {
  id String @id @default(uuid())
  clientId String
  engineerId String?

  title String
  description String @db.Text
  budget Float
  instruments String[]
  roadmapFiles String[]
  
  advancePaid Boolean @default(false)
  status ProjectStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client ClientProfile @relation(fields: [clientId], references: [id])
  engineer EngineerProfile? @relation(fields: [engineerId], references: [id])
}