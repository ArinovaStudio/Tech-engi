generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

enum Role {
  ADMIN
  CLIENT
  ENGINEER
}

model User {
  id String @id @default(uuid())
  name String?
  email String @unique
  emailVerified DateTime?
  password String?
  role Role  
  image String?
  lastActiveAt DateTime @default(now())

  accounts Account[]
  clientProfile ClientProfile?
  engineerProfile EngineerProfile?
  raisedTickets Ticket[]
  addedResources ProjectResource[]
}

model ClientProfile {
  id String @id @default(uuid())
  userId String @unique
  totalProjects Int @default(0)
  totalBudget Float @default(0)
  expertise String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Qualification {
  UG
  EMPLOYED
  UNEMPLOYED
}

enum IdType {
  STUDENT_ID
  AADHAAR
  PAN
  PAY_SLIP
}

model EngineerProfile {
  id String @id @default(uuid())
  userId String @unique

  status ApprovalStatus @default(PENDING)
  rejectionReason String? @db.Text
  qualification Qualification
  idType IdType
  idNumber String
  idImage String
  
  certifications String[]
  skills String[]
  embedding Unsupported("vector(768)")?
  completedProjects Int @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedWork Project[]
  invitations ProjectInvitation[]
}

model Account {
  id String @id @default(uuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? @db.Text
  access_token String? @db.Text
  expires_at Int?
  token_type String?
  scope String?
  id_token String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum ProjectStatus {
  DRAFT
  AWAITING_ADVANCE
  SEARCHING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELED
}

model Project {
  id String @id @default(uuid())
  clientId String
  engineerId String?

  title String
  description String @db.Text
  budget Float
  instruments String[]
  
  advancePaid Boolean @default(false)
  status ProjectStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client ClientProfile @relation(fields: [clientId], references: [id])
  engineer EngineerProfile? @relation(fields: [engineerId], references: [id])

  invitations ProjectInvitation[]
  tickets Ticket[]
  resources ProjectResource[]
  deletionRequest ProjectDeletionRequest?
}

enum ResourceType {
  FILE
  CREDENTIALS
  IMAGE
  LINK
  TEXT
}

model ProjectResource {
  id String @id @default(uuid())
  projectId String
  addedById String

  title String
  type ResourceType
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedBy User  @relation(fields: [addedById], references: [id], onDelete: Cascade)
}

enum InvitationStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model ProjectInvitation {
  id String @id @default(uuid())
  projectId String
  engineerId String
  status InvitationStatus @default(SENT)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  engineer EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([projectId, engineerId])
}

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProjectDeletionRequest {
  id String @id @default(uuid())
  projectId String @unique 
  reason String @db.Text
  status DeletionRequestStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum TicketType {
  PAYMENT
  COMMUNICATION
  TECHNICAL
  DELIVERY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Ticket {
  id String @id @default(uuid())
  projectId String
  raisedById String       

  issueType TicketType
  description String @db.Text
  images String[]
  status TicketStatus @default(OPEN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedBy User @relation(fields: [raisedById], references: [id], onDelete: Cascade)
}

enum Otptype {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model Otp {
  id String @id @default(uuid())
  email String
  code String
  type Otptype
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type])
}